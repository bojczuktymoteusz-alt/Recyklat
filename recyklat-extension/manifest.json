{
  "manifest_version": 3,
  "name": "Recyklat FB Contacts",
  "version": "1.7",
  "description": "Contact verification & lead capture for recyklat.pl Facebook groups",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "http://localhost:17731/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["contacts-db.js", "fuzzy.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["messages.json"],
      "matches": ["https://www.facebook.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Recyklat Contacts"
  }
}
